{
  "parameters": {
    "db": {
      "hostname": "my-elasticsearch-host",
      "port": 9200
    },
    "scheme": "https",
    "authentication": {
      "auth_type": "basic",
      "username": "elastic",
      "#password": "changeme"
    },
    "index_name": "search_analytics-{{date}}",
    "request_body": "{\"query\": {\"match_all\": {}}, \"sort\": [{\"_doc\": \"asc\"}]}",
    "date": {
      "shift": "yesterday",
      "format": "%Y.%m.%d",
      "time_zone": "UTC"
    },
    "storage_table": "search_analytics",
    "primary_keys": ["_id"],
    "incremental": true,
    "include_meta_fields": true
  }
}
